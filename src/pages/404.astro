---
import Header from '../components/Header.astro';
import Body from '../components/Body.astro';
import Footer from '../components/Footer.astro';
import Content from '../components/Content.astro';
---

<Body>
  <Header hideRoute />
  <main class="pt-[56px]">
    <Content>
      <h1 class="pb-4 mb-6 font-head text-3xl border-b-2 border-neutral-200">
        Not Found
      </h1>
    </Content>
  </main>
  <Footer />
  <div
    class="text-4xl text-2xl text-xl text-lg mb-6 mb-3 p-2 rounded-md text-left pl-6 border border-l-4 list-disc list-decimal ml-[1.1rem]"
  >
  </div>
</Body>
